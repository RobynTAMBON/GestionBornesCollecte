<Window x:Class="GestionBornesCollecte.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionBornesCollecte.Wpf"
        mc:Ignorable="d"
        Title="Test SignalR" Height="450" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Background="Red">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition x:Name="DetailColumn" Width="0"/>
        </Grid.ColumnDefinitions>


        <!-- GAUCHE : Liste -->
        <ScrollViewer Grid.Column="0" Background="#F5F6FA">
            <ItemsControl ItemsSource="{Binding Bennes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>


                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button 
                            Margin="12"
                            Padding="0"
                            BorderThickness="0"
                            Background="Transparent"
                            Click="Benne_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <Border CornerRadius="12" Background="White" Padding="15">

                                <!-- Ombre -->
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                                </Border.Effect>

                                <Grid Margin="15" MinHeight="200" MinWidth="400">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Barre couleur état -->
                                    <Border Grid.Column="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Gray"/>

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Etat}" Value="OK">
                                                        <Setter Property="Background" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Etat}" Value="ALERTE">
                                                        <Setter Property="Background" Value="#FF9800"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Etat}" Value="PLEINE">
                                                        <Setter Property="Background" Value="#F44336"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Contenu -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock 
                                    Text="{Binding Nom}" 
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="#2C3E50"/>

                                        <TextBlock 
                                    Text="{Binding Etat}" 
                                    FontSize="12"
                                    Foreground="Gray"
                                    Margin="0,0,0,8"/>

                                        <!-- Niveau -->
                                        <TextBlock Text="Niveau" FontSize="12" Foreground="Gray"/>
                                        <ProgressBar 
                                    Value="{Binding NiveauRemplissage}" 
                                    Maximum="100"
                                    Height="10"
                                    Margin="0,2,0,8"/>

                                        <!-- Batterie -->
                                        <TextBlock 
                                    Text="{Binding BatterieVolt, StringFormat=Batterie : {0} V}" 
                                    FontSize="12"
                                    Foreground="#555"/>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Droite : Détails de la benne sélectionnée -->
        <Border Grid.Column="1"
        Background="White"
        Padding="20">

            <StackPanel DataContext="{Binding SelectedBenne}">
                <TextBlock Text="{Binding Nom}" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="{Binding Etat}" Margin="0,5,0,15"/>

                <TextBlock Text="Niveau"/>
                <ProgressBar Value="{Binding NiveauRemplissage}" Maximum="100"/>

                <TextBlock Text="{Binding BatterieVolt, StringFormat=Batterie : {0} V}" Margin="0,10,0,0"/>
            </StackPanel>

        </Border>


    </Grid>


</Window>
